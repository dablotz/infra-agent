{
  "openapi": "3.0.0",
  "info": {
    "title": "IaC Generator API",
    "version": "1.0.0",
    "description": "API for generating Infrastructure as Code"
  },
  "paths": {
    "/generate-iac": {
      "post": {
        "summary": "Generate Infrastructure as Code",
        "description": "Generates validated and security-scanned IaC from natural language description. Runs the full pipeline synchronously and returns the S3 location of the generated artifact.",
        "operationId": "generateIaC",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "user_request": {
                    "type": "string",
                    "description": "Natural language description of the infrastructure to create"
                  },
                  "iac_type": {
                    "type": "string",
                    "description": "Type of IaC to generate (terraform, cloudformation, or cdk)",
                    "enum": ["terraform", "cloudformation", "cdk"],
                    "default": "terraform"
                  }
                },
                "required": ["user_request"]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "IaC generated, validated, and security-scanned successfully",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": {
                      "type": "string"
                    },
                    "s3_uri": {
                      "type": "string",
                      "description": "S3 URI where the generated IaC artifact can be retrieved"
                    },
                    "s3_bucket": {
                      "type": "string"
                    },
                    "s3_key": {
                      "type": "string"
                    },
                    "iac_type": {
                      "type": "string"
                    },
                    "validation_status": {
                      "type": "string"
                    },
                    "security_status": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Invalid request",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "error": { "type": "string" }
                  }
                }
              }
            }
          },
          "500": {
            "description": "Pipeline execution failed",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "error": { "type": "string" }
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}
